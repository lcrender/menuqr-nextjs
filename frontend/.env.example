# Plantilla para desarrollo local con `npm run dev` en /frontend.
# Copiá a `.env.local` (gitignored) y ajustá. Detalle: docs/ENV-LOCAL.md
#
# API en el navegador (mismo host que el front → CORS en backend debe incluir NEXT_PUBLIC_APP_URL)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Opcional — Checkout Bricks / SDK (mismo entorno que el modo MP activo en el panel super admin)
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY_TEST=
# Formulario público de contacto (Google reCAPTCHA invisible v2)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# Cookies / GTM — docs/COOKIE-CONSENT.md
# NEXT_PUBLIC_GTM_CONTAINER_ID=GTM-XXXX
# NEXT_PUBLIC_GTM_DEV=true
# NEXT_PUBLIC_GTM_DISABLED=true

# Backend directo para Node (getServerSideProps, fetch sin navegador). Obligatorio si el build usa
# NEXT_PUBLIC_API_URL=/api-proxy (el servidor no puede llamar a sí mismo vía path relativo).
# Misma idea que INTERNAL_API_URL en next.config.js (rewrite /api-proxy → backend).
# INTERNAL_API_URL=http://backend:3001
# INTERNAL_API_URL=http://127.0.0.1:3001
