# ========================================
# AppMenuQR - Variables de Entorno
# ========================================
# Desarrollo local: qué archivo usa cada servicio → docs/ENV-LOCAL.md
# Frontend Next (NEXT_PUBLIC_*): plantilla en frontend/.env.example → copiar a frontend/.env.local

# ========================================
# BASE DE DATOS
# ========================================
DATABASE_URL="postgresql://menuqr_user:menuqr_password@localhost:5432/menuqr"

# ========================================
# REDIS (obligatorio; servicio en Docker dev/prod)
# El backend aún no usa Redis para caché — ver backend/docs/REDIS.md
# ========================================
REDIS_URL="redis://localhost:6379"

# ========================================
# JWT - TOKENS
# ========================================
JWT_SECRET="tu-secret-super-seguro-y-unico-aqui"
JWT_REFRESH_SECRET="tu-refresh-secret-super-seguro-y-unico-aqui"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ========================================
# MINIO - STORAGE
# ========================================
MINIO_ENDPOINT="localhost"
MINIO_PORT="9000"
MINIO_ACCESS_KEY="admin"
MINIO_SECRET_KEY="admin123"
MINIO_BUCKET="menuqr-assets"
MINIO_USE_SSL="false"
MINIO_REGION="us-east-1"

# ========================================
# EMAIL - SMTP
# ========================================
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="tu-email@gmail.com"
SMTP_PASS="tu-app-password"
SMTP_FROM="noreply@menuqr.com"
SMTP_FROM_NAME="AppMenuQR"

# ========================================
# APLICACIÓN
# ========================================
NODE_ENV="development"
PORT="3001"
FRONTEND_URL="http://localhost:3000"
BACKEND_URL="http://localhost:3001"

# ========================================
# RATE LIMITING
# ========================================
RATE_LIMIT_WINDOW_MS="900000"  # 15 minutos
RATE_LIMIT_MAX_REQUESTS="100"  # 100 requests por ventana

# ========================================
# LOGGING
# ========================================
LOG_LEVEL="info"
LOG_FORMAT="json"

# ========================================
# CORS
# ========================================
CORS_ORIGIN="http://localhost:3000"
CORS_CREDENTIALS="true"

# ========================================
# SEGURIDAD
# ========================================
BCRYPT_ROUNDS="12"
PASSWORD_MIN_LENGTH="8"
PASSWORD_REQUIRE_UPPERCASE="true"
PASSWORD_REQUIRE_LOWERCASE="true"
PASSWORD_REQUIRE_NUMBERS="true"
PASSWORD_REQUIRE_SPECIAL_CHARS="true"

# ========================================
# CACHE
# ========================================
CACHE_TTL="3600"  # 1 hora en segundos
MENU_CACHE_TTL="1800"  # 30 minutos para menús

# ========================================
# QR
# ========================================
QR_SIZE="300"
QR_MARGIN="2"
QR_COLOR="000000"
QR_BACKGROUND="FFFFFF"

# ========================================
# PLANES Y LÍMITES
# ========================================
FREE_PLAN_RESTAURANT_LIMIT="1"
FREE_PLAN_MENU_LIMIT="3"
FREE_PLAN_ITEM_LIMIT="50"

# ========================================
# MERCADO PAGO (Argentina — API / suscripciones / Checkout Bricks)
# ========================================
# Modo sandbox|production: super admin → Configuración → Mercado Pago (app_settings).
# MERCADOPAGO_ACCESS_TOKEN = producción | MERCADOPAGO_ACCESS_TOKEN_TEST = prueba/sandbox
MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_ACCESS_TOKEN_TEST=""
# Desarrollo local: Mercado Pago rechaza back_url con localhost. Usá ngrok (u otro túnel) al puerto del front y:
# MERCADOPAGO_PUBLIC_FRONTEND_URL="https://TU-SUBDOMINIO.ngrok-free.app"
# Abrí el admin con esa misma URL en el navegador para que cookies y redirects coincidan.
# Recomendado en producción: clave de firma de webhooks (panel Mercado Pago → Tus integraciones → Webhooks).
# Sin esto, el backend acepta notificaciones sin verificar x-signature (solo desarrollo).
# MERCADOPAGO_WEBHOOK_SECRET=""
# Opcional — Bricks / SDK (frontend). Deben coincidir con el modo MP activo.
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=""
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY_TEST=""

# ========================================
# FRONTEND — Google Tag Manager y consentimiento de cookies
# (GTM solo se carga tras "Aceptar" en el banner; ver docs/COOKIE-CONSENT.md)
# ========================================
# NEXT_PUBLIC_GTM_CONTAINER_ID="GTM-XXXX"
# NEXT_PUBLIC_GTM_DEV="true"
# NEXT_PUBLIC_GTM_DISABLED="true"

# ========================================
# DESARROLLO
# ========================================
DEBUG="true"
SEED_DATA="true"
SKIP_EMAIL_VERIFICATION="true"

# ========================================
# PAYPAL - SUSCRIPCIONES
# ========================================
# PAYPAL_MODE="sandbox"
# PAYPAL_CLIENT_ID=""
# PAYPAL_SECRET=""
# PAYPAL_WEBHOOK_ID=""  # ID del webhook en dashboard PayPal (para verificar firma)
# PAYPAL_PLAN_ID_MONTHLY=""   # Plan ID mensual (creado en PayPal)
# PAYPAL_PLAN_ID_YEARLY=""   # Plan ID anual
# PAYPAL_BRAND_NAME="AppMenuQR"
# Opcional: plan IDs por nivel para mapear subscription_plan (starter, pro, premium). PayPal sigue usando PAYPAL_PLAN_ID_BASIC_* para el plan Starter.
# PAYPAL_PLAN_ID_BASIC_MONTHLY=""
# PAYPAL_PLAN_ID_PRO_MONTHLY=""
# PAYPAL_PLAN_ID_PREMIUM_MONTHLY=""

# reCAPTCHA v3 invisible: contacto público y registro (/login). Backend: si falta GOOGLE_RECAPTCHA_SECRET_KEY, el registro no exige token (útil en local).
# GOOGLE_RECAPTCHA_SECRET_KEY=""
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""
# CONTACT_FORM_RECEIVER_EMAIL="lcrender@gmail.com"

# Email para notificaciones de nuevos tickets de soporte (panel admin). Si falta: CONTACT_FORM_RECEIVER_EMAIL o primer usuario SUPER_ADMIN.
# SUPPORT_TICKETS_ADMIN_EMAIL="admin@tu-dominio.com"

# ========================================
# PRODUCCIÓN (cambiar en deploy)
# ========================================
# Ejemplo con docker-compose.prod.yml y dominio appmenuqr.com:
# FRONTEND_URL="https://appmenuqr.com"
# BACKEND_URL="https://api.appmenuqr.com"
# CORS: varios orígenes separados por coma (si el front llama directo a la API)
# CORS_ORIGIN="https://appmenuqr.com,https://www.appmenuqr.com"
# NEXT_PUBLIC_APP_URL="https://appmenuqr.com"
# En prod con docker-compose.prod.yml el FRONT se builda siempre con NEXT_PUBLIC_API_URL=/api-proxy
# (no pongas NEXT_PUBLIC_API_URL=https://api... en .env para el build del front: reactiva CORS).
# CORS_ORIGIN debe listar el dominio del sitio (ej. https://appmenuqr.com,https://www.appmenuqr.com)
# por si algún cliente o caché sigue llamando directo a la API.
# NEXT_PUBLIC_API_URL="https://api.appmenuqr.com"
# MINIO_PUBLIC_URL="https://s3.appmenuqr.com"
# NODE_ENV="production"
# DEBUG="false"
# SEED_DATA="false"
# SKIP_EMAIL_VERIFICATION="false"
# MINIO_USE_SSL="true"

